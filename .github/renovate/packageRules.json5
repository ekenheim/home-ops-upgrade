{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": ["Semver versioning for nordic-housing images"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/ghcr.io\\/ekenheim\\/nordic-housing/"],
      "versioning": "semver"
    },
    {
      "description": ["Loose versioning for non-semver packages"],
      "matchDatasources": ["docker"],
      "versioning": "loose",
      "matchPackageNames": ["/plex/"]
    },
    {
      "description": ["Custom versioning for mylar3"],
      "matchDatasources": ["docker"],
      "versioning": "regex:^version-v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      "matchPackageNames": ["/mylar3/"]
    },
    {
      "description": ["Process terraform files"],
      "matchManagers": ["terraform"],
      "matchDatasources": ["terraform-provider"],
      "versioning": "terraform",
      "matchPackagePatterns": [".*"]
    },
    {
      // Hold Kubernetes < 1.36 until Talos 1.13 GAs — talosctl 1.12.x
      // refuses the 1.35 -> 1.36 upgrade path. Lift this rule in the same
      // PR that bumps ghcr.io/siderolabs/installer to v1.13.x.
      "description": ["Pin kubelet/kubectl to <1.36 (awaiting Talos 1.13 GA)"],
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/siderolabs/kubelet",
        "registry.k8s.io/kubectl"
      ],
      "allowedVersions": "<1.36.0"
    },
    {
      // Hold rayproject/ray < 2.55 until grid-resilience-ray-worker is
      // rebuilt against Ray 2.55.x. Ray enforces an exact head/worker
      // version match — drift here breaks the cluster (workers stuck in
      // wait-gcs-ready). Lift this rule in the same PR that bumps
      // ghcr.io/ekenheim/grid-resilience-ray-worker.
      "description": ["Pin rayproject/ray to <2.55 (awaiting worker rebuild)"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["rayproject/ray"],
      "allowedVersions": "<2.55.0"
    }
  ]
}